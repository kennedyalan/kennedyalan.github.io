---
import { Image } from "astro:assets";
import GitHub from "./icons/GitHub.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import { TAGS } from "./tags/Tags.ts";
import temploImg from "../../public/projects/templo.png";
import brainscriptorImg from "../../public/projects/brainscriptor.png";
import dumasImg from "../../public/projects/dumas.png";
import shelbyImg from "../../public/projects/shelby.png";
import ecommerceImg from "../../public/projects/Ecommerce-API.jpg";

const PROJECTS = [
  {
    title: "El Templo del Fútbol 5 - Sistema de reserva de canchas",
    description:
      "Plataforma web para la reserva online de canchas de fútbol 5 en un complejo deportivo de Corrientes, Argentina. Permite seleccionar fechas, horarios y duración de la reserva, con confirmación vía WhatsApp.",
    link: "https://eltemplodelfutbol5.com",
    image: temploImg,
    tags: [TAGS.NEXT, TAGS.REACT, TAGS.TYPESCRIPT, TAGS.TAILWIND],
  },
  {
    title: "Brainscriptor - Plataforma digital psicofármacos",
    description:
      "Plataforma digital para la asistencia de prescripción personalizada de psicofármacos. Trabajé conjunto a un equipo de 3 desarrolladores, 1 product designer y 1 project manager. Actualmente en busca de financiación.",
    link: "https://app.brainscriptor.com/",
    image: brainscriptorImg,
    tags: [TAGS.NEXT, TAGS.REACT, TAGS.HTML, TAGS.CSS, TAGS.JAVASCRIPT],
  },
  {
    title: "Dumas Distribuciones - Tienda Web para distribuidora",
    description:
      "Solución integral para una empresa de distribución de productos para veterinarias. Integración con Mercado Pago y Firebase para almacenamiento de imágenes. Trabajo en equipo.",
    link: "https://dumasdistribuciones.com.ar",
    image: dumasImg,
    tags: [TAGS.JAVA, TAGS.SPRING, TAGS.REACT, TAGS.TYPESCRIPT, TAGS.TAILWIND, TAGS.POSTGRESQL],
  },
  {
    title: "Shelby Peluquería - Landing y Reserva de turnos",
    description:
      "Pagina web landing y sistema de reserva de turnos para una peluquería. Se incrementaron en un 80% las reservas de turnos. Aumento del 65% de clientes nuevos.",
    link: "https://shelbypeluqueria.com",
    image: shelbyImg,
    tags: [TAGS.REACT, TAGS.HTML, TAGS.CSS, TAGS.TYPESCRIPT, TAGS.TAILWIND],
  },
  {
    title: "E-commerce API - Proyecto final de Bootcamp Globant",
    description:
      "E-commerce API diseñado para administrar productos, carritos y clientes. Implementado con los patrones de diseño \"decorator\" y \"factory\" y arquitectura MVC. Aprendí mucho sobre buenas practicas y diseño de API REST.",
    github: "https://github.com/Alankke/Ecommerce",
    image: ecommerceImg,
    tags: [TAGS.JAVA, TAGS.SPRING, TAGS.DOCKER, TAGS.RABBITMQ],
  },
];
---

<div class="flex flex-col divide-y divide-gray-200/70 dark:divide-gray-800/70">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }, index) => {
      const sep = title.indexOf(" - ");
      const name = sep > -1 ? title.slice(0, sep) : title;
      const category = sep > -1 ? title.slice(sep + 3) : "";
      return (
        <article class="group py-12 first:pt-0 last:pb-0">

          <div class="flex items-center gap-3 mb-6">
            <span class="font-display text-xs font-bold tracking-[0.2em] text-yellow-500 dark:text-yellow-400 tabular-nums">
              {String(index + 1).padStart(2, "0")}
            </span>
            <div class="h-px flex-1 bg-gray-300/60 dark:bg-gray-700/60" />
            {category && (
              <span class="text-[0.65rem] tracking-[0.18em] uppercase text-gray-500 dark:text-gray-500 font-medium">
                {category}
              </span>
            )}
          </div>

          <div
            class="relative overflow-hidden rounded-2xl w-full mb-7 shadow-md transition-shadow duration-500 group-hover:shadow-xl ring-1 ring-gray-200/80 dark:ring-gray-800/80"
            style="aspect-ratio: 16/7;"
          >
            <Image
              src={image}
              alt={`Captura de pantalla de ${name}`}
              class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.02]"
            />
            {link && (
              <a
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                class="absolute top-3 right-3 size-8 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 hover:bg-yellow-500"
                aria-label={`Abrir ${name}`}
              >
                <Link class="size-3.5" />
              </a>
            )}
          </div>

          <div class="grid md:grid-cols-[1fr_auto] gap-x-12 gap-y-6 items-start">
            <div class="flex flex-col gap-3">
              <h3 class="font-display text-2xl md:text-[1.85rem] font-bold text-gray-900 dark:text-white leading-tight tracking-tight">
                {name}
              </h3>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-[0.925rem] max-w-2xl">
                {description}
              </p>
            </div>

            <div class="flex flex-col gap-4 md:items-end md:min-w-[190px]">
              <ul class="flex flex-wrap gap-2 md:justify-end">
                {tags.map((tag) => (
                  <li>
                    <span
                      class={`flex items-center gap-1.5 text-xs ${tag.class} py-1 px-2.5 rounded-full font-medium`}
                    >
                      <tag.icon class="size-3.5" />
                      {tag.name}
                    </span>
                  </li>
                ))}
              </ul>
              <div class="flex gap-2 flex-wrap md:justify-end">
                {github && (
                  <LinkButton href={github}>
                    <GitHub class="size-4" />
                    Repositorio
                  </LinkButton>
                )}
                {link && (
                  <LinkButton href={link}>
                    <Link class="size-4" />
                    Ver proyecto
                  </LinkButton>
                )}
              </div>
            </div>
          </div>

        </article>
      );
    })
  }
</div>
