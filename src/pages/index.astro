---
import AboutMe from "../components/AboutMe.astro";
import Experience from "../components/Experience.astro";
import Hero from "../components/Hero.astro";
import Projects from "../components/Projects.astro";
import Education from "../components/Education.astro";
import SectionContainer from "../components/SectionContainer.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Portfolio de Alan Kennedy - Desarrollador Full Stack"
	description="Desarrollador Full Stack con +2 años de experiencia en React, Next.js, Spring Boot y TypeScript. Disponible para proyectos freelance desde Corrientes, Argentina."
>
	<main class="px-4">
		<SectionContainer class="py-16 md:py-36">
			<Hero />
		</SectionContainer>
	</main>
	<div class="space-y-24">
		<SectionContainer id="experiencia">
			<h2
				class="font-display text-fluid-section font-bold mb-6 border-l-[3px] border-yellow-500 pl-4 text-black/80 dark:text-white"
			>
				Experiencia laboral
			</h2>
			<Experience />
		</SectionContainer>

		<SectionContainer id="proyectos">
			<h2
				class="font-display text-fluid-section font-bold mb-6 border-l-[3px] border-yellow-500 pl-4 text-black/80 dark:text-white"
			>
				Proyectos
			</h2>
			<Projects />
		</SectionContainer>

		<SectionContainer id="educación">
      <h2 class="font-display text-fluid-section font-bold mb-6 border-l-[3px] border-yellow-500 pl-4 text-black/80 dark:text-white">
        Educación
      </h2>
      <Education />
    </SectionContainer>

		<SectionContainer id="sobre-mi">
			<h2
				class="font-display text-fluid-section font-bold mb-6 border-l-[3px] border-yellow-500 pl-4 text-black/80 dark:text-white"
			>
				Sobre mí
			</h2>
			<AboutMe />
		</SectionContainer>
	</div>
</Layout>
